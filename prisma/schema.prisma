generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  full_name String
  email String @unique
  password_hash String
  status UserStatus @default(ACTIVE)
  picture_url String?
  role GlobalRole @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  clinic_members ClinicMember[]

  @@index([status])
  @@map("users")
}

model Clinic {
  id String @id @default(uuid())
  name String
  slug String @unique
  type ClinicType @default(OTHER)
  cnpj String?
  phone String?
  email String?
  address String?
  postal_code String?
  city String?
  state String?
  status ClinicStatus @default(ACTIVE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  members ClinicMember[]
  subscriptions Subscription[]
  clinic_settings ClinicSettings?
  working_hours ClinicWorkingHour[]
  special_dates ClinicSpecialDate[]
  services ClinicService[]
  appointments Appointments[]
  whatsapp_session WhatsAppSession?

  @@index([status])
  @@map("clinics")
}

model ClinicSettings {
  id String @id @default(uuid())
  clinic_id String @unique
  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  charges_evaluation Boolean @default(false)
  evaluation_price_cents Int?
  max_appointments_per_slot Int? @default(1)
  appointment_duration_minutes Int? @default(60)
  allow_rescheduling Boolean @default(true)
  allow_cancellation Boolean @default(true)
  timezone String @default("America/Sao_Paulo")
  ai_agent_name String @default("Aurora")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("clinic_settings")
}

model Appointments {
  id String @id @default(uuid())
  clinic_id String
  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  service_id String?
  service ClinicService? @relation(fields: [service_id], references: [id], onDelete: SetNull)
  customer_phone_number String
  appointment_date DateTime
  status AppointmentStatus @default(PENDING)
  notes String?

  @@map("appointments")
}

model ClinicWorkingHour {
  id String @id @default(uuid())
  clinic_id String
  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  weekday Weekday
  start_time String
  end_time String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([clinic_id, weekday])
  @@map("clinic_working_hours")
}

model ClinicSpecialDate {
  id String @id @default(uuid())
  clinic_id String
  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  date String
  is_open Boolean
  start_time String?
  end_time String?
  note String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([clinic_id, date])
  @@index([clinic_id, date])
  @@map("clinic_special_dates")
}

model ClinicService {
  id String @id @default(uuid())
  clinic_id String
  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  name String
  appointments Appointments[]
  duration_minutes Int
  price_cents Int?
  created_at DateTime @default(now())

  @@map("clinic_services")
}

model ClinicMember {
  id String @id @default(uuid())
  clinic_id String
  clinic Clinic @relation(fields: [clinic_id], references: [id])
  user_id String
  user User @relation(fields: [user_id], references: [id])
  role ClinicRole @default(MEMBER)
  status MemberStatus @default(ACTIVE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([clinic_id, user_id])
  @@index([user_id])
  @@index([clinic_id])
  @@map("clinic_members")
}

model Plan {
  id String @id @default(uuid())
  stripe_price_id String? @unique
  name String
  description String?
  code String @unique
  price_monthly Int
  trial_days Int @default(7)
  max_users Int?
  max_whatsapp_sessions Int?
  max_monthly_appointments Int? @default(50)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id String @id @default(uuid())
  clinic_id String
  clinic Clinic @relation(fields: [clinic_id], references: [id])
  plan_id String
  plan Plan @relation(fields: [plan_id], references: [id])
  status SubscriptionStatus
  trial_ends_at DateTime?
  current_period_start DateTime?
  current_period_end DateTime?
  cancel_at_period_end Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([clinic_id])
  @@index([clinic_id, status])
  @@index([plan_id])
  @@map("subscriptions")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClinicStatus {
  ACTIVE
  SUSPENDED
}

enum ClinicRole {
  OWNER
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INVITED
  REMOVED
}

enum SubscriptionStatus {
  TRIALING
  PAST_DUE
  ACTIVE
  CANCELED
}

enum GlobalRole {
  ADMIN
  USER
}

enum ClinicType {
  DENTAL
  MEDICAL
  AESTHETIC
  PSYCHOLOGY
  OTHER
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

model WhatsAppSession {
  id String @id @default(uuid())
  clinic_id String @unique
  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  session_name String @unique
  status WhatsAppSessionStatus @default(STARTING)
  phone_number String?
  engine String @default("WEBJS")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@map("whatsapp_sessions")
}

enum WhatsAppSessionStatus {
  STARTING
  SCAN_QR_CODE
  WORKING
  FAILED
  STOPPED
}
